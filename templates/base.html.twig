<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{% block title %}Vite & Gourmand{% endblock %}</title>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🍽️</text></svg>">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

    {% block stylesheets %}
        <!-- Bootstrap -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

        <!-- CSS -->
        <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    {% endblock %}
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark">
<div class="container">

<a class="navbar-brand" href="{{ path('app_home') }}">Vite & Gourmand</a>

<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
<span class="navbar-toggler-icon"></span>
</button>

<div class="collapse navbar-collapse" id="navbarNav">
<ul class="navbar-nav ms-auto">

<li class="nav-item">
<a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
</li>

<li class="nav-item">
<a class="nav-link" href="{{ path('app_menus') }}">Nos Menus</a>
</li>

<li class="nav-item">
<a class="nav-link" href="{{ path('app_contact') }}">Contact</a>
</li>

{% if is_granted('ROLE_ADMIN') %}
<li class="nav-item">
    <a class="nav-link" href="{{ path('admin') }}">Admin</a>
</li>
{% endif %}

{% if is_granted('ROLE_EMPLOYE') and not is_granted('ROLE_ADMIN') %}
<li class="nav-item">
    <a class="nav-link" href="{{ path('app_employe') }}">Espace Employé</a>
</li>
{% endif %}

{% if is_granted('ROLE_USER') and not is_granted('ROLE_ADMIN') and not is_granted('ROLE_EMPLOYE') %}
<li class="nav-item">
<a class="nav-link" href="{{ path('app_account') }}">Mon compte</a>
</li>
{% endif %}

{% if app.user %}
<li class="nav-item">
<a class="nav-link" href="{{ path('app_logout') }}">Déconnexion</a>
</li>
{% else %}
<li class="nav-item">
<a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
</li>
{% endif %}

</ul>
</div>
</div>
</nav>

<!-- CONTENU -->
<div class="container mt-5">
    {% block body %}{% endblock %}
</div>

<!-- FOOTER -->
<footer class="text-white mt-5 pt-4 pb-3">
    <div class="container">
        <div class="row">

            <div class="col-md-4 mb-3">
                <h5>Horaires</h5>
                <ul class="list-unstyled">
                    <li>Lundi - Jeudi : 11h00 - 22h00</li>
                    <li>Vendredi - Samedi : 11h00 - 23h00</li>
                    <li>Dimanche : 12h00 - 21h00</li>
                </ul>
            </div>

            <div class="col-md-4 mb-3">
                <h5>Informations</h5>
                <ul class="list-unstyled">
                    <li><a href="{{ path('app_legal') }}" class="text-white text-decoration-none">Mentions légales</a></li>
                    <li><a href="{{ path('app_cgv') }}" class="text-white text-decoration-none">CGV</a></li>
                    <li><a href="{{ path('app_privacy') }}" class="text-white text-decoration-none">Confidentialité</a></li>
                </ul>
            </div>

            <div class="col-md-4 mb-3">
                <h5>Vite & Gourmand</h5>
                <p>Le goût authentique, rapidement.</p>
            </div>

        </div>

        <hr style="border-color: #444;">

        <div class="text-center">
            <small>© {{ "now"|date("Y") }} Vite & Gourmand - Tous droits réservés</small>
        </div>
    </div>
</footer>

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}

</body>
</html>