{% extends 'base.html.twig' %}

{% block title %}Chiffre d'affaires{% endblock %}

{% block body %}

<div class="container mt-5">

<div class="mb-4">
<a href="{{ path('admin') }}" class="btn btn-secondary">
← Retour au Dashboard
</a>
</div>

<h1 class="mb-4">Chiffre d'affaires par menu</h1>

<table class="table table-striped mt-4">

<thead>
<tr>
<th>Menu</th>
<th>Chiffre d'affaires (€)</th>
</tr>
</thead>

<tbody>

{% for item in ca %}

<tr>
<td>{{ item.menu }}</td>
<td>{{ item.chiffre }}</td>
</tr>

{% endfor %}

</tbody>

</table>

</div>

{% endblock %}