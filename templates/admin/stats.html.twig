{% extends 'base.html.twig' %}

{% block body %}

<div class="container mt-5">

<div class="mb-4">
<a href="{{ path('admin') }}" class="btn btn-secondary">
← Retour au Dashboard
</a>
</div>

<h1 class="mb-4">Statistiques des commandes par menu</h1>

<canvas id="chart" data-stats='{{ stats|json_encode|e("html_attr") }}'></canvas>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const canvas = document.getElementById('chart');
const statsData = JSON.parse(canvas.dataset.stats);

const labels = statsData.map(item => item.menu);
const dataValues = statsData.map(item => item.total);

new Chart(canvas, {
    type: 'bar',
    data: {
        labels: labels,
        datasets: [{
            label: 'Commandes par menu',
            data: dataValues
        }]
    }
});

</script>

{% endblock %}