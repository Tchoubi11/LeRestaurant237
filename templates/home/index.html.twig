{% extends 'base.html.twig' %}

{% block body %}

<!-- HERO SECTION -->
<section class="hero">
    <div class="container text-center text-white">
        <h1 class="hero-title">Vite & Gourmand</h1>
        <p class="hero-subtitle">Le goût authentique, rapidement.</p>

        <a href="{{ path('app_menus') }}" class="btn btn-gold btn-lg mt-4">
            🍽 Découvrir nos menus
        </a>
    </div>
</section>

<!-- INTRO -->
<section class="container mt-5">

    <div class="text-center mb-5">
        <h2 class="section-title">Bienvenue chez Vite & Gourmand</h2>
        <p class="section-subtitle">25 ans d'excellence culinaire à Bordeaux</p>
    </div>

    <div class="row">

        <!-- ENTREPRISE -->
        <div class="col-md-6 mb-4">
            <div class="info-card h-100">
                <div class="icon">🏢</div>
                <h3>Notre entreprise</h3>
                <p>
                    Depuis 25 ans à Bordeaux, Julie et José proposent
                    des menus gastronomiques pour tous vos événements.
                </p>
            </div>
        </div>

        <!-- PROFESSIONNALISME -->
        <div class="col-md-6 mb-4">
            <div class="info-card h-100">
                <div class="icon">👨‍🍳</div>
                <h3>Notre professionnalisme</h3>
                <p>
                    Une équipe passionnée, des produits frais,
                    un service rapide et une qualité irréprochable.
                </p>
            </div>
        </div>

    </div>

</section>

    <!-- AVIS CLIENTS -->
    <h2 class="mb-3">Avis clients</h2>

    <div class="row">
    {% for avis in avis %}
        <div class="col-md-4 mb-4">
            <div class="card avis-card h-100">

                <div class="card-body">

                    <h5 class="fw-bold">
                        {{ avis.user.prenom }} {{ avis.user.nom }}
                    </h5>

                    <p class="text-muted small">
                        {{ avis.dateAvis|date('d/m/Y') }}
                    </p>

                    <div class="mb-2">
                        {% for i in 1..5 %}
                            {% if i <= avis.note %}
                                <span class="star filled">★</span>
                            {% else %}
                                <span class="star">★</span>
                            {% endif %}
                        {% endfor %}
                    </div>

                    <p class="mt-2">
                        “{{ avis.commentaire }}”
                    </p>

                </div>

            </div>
        </div>
    {% endfor %}
</div>
</div>

{% endblock %}