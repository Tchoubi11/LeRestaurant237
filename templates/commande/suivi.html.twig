{% extends 'base.html.twig' %}

{% block body %}

<h2>Suivi de ma commande</h2>

<p><strong>Statut actuel :</strong> {{ commande.statut }}</p>

<h3>Historique</h3>

{% for historique in commande.historiques %}
    <div class="card mb-2 p-2">
        <strong>{{ historique.statut }}</strong><br>
        <small>{{ historique.dateModification|date('d/m/Y H:i') }}</small>
    </div>
{% else %}
    <p>Aucun historique enregistré.</p>
{% endfor %}

<a href="{{ path('app_account') }}" class="btn btn-secondary mt-3">
    Retour
</a>

{% endblock %}