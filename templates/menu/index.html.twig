{% extends 'base.html.twig' %}

{% block title %}Menus{% endblock %}

{% block body %}

{% if is_granted('ROLE_ADMIN') %}
<a href="{{ path('admin') }}" class="btn btn-secondary mb-3">
    ← Retour au dashboard 
</a>

{% elseif is_granted('ROLE_EMPLOYE') %}
<a href="{{ path('app_employe') }}" class="btn btn-secondary mb-3">
    ← Retour au dashboard 
</a>
{% endif %}

<div class="container mt-5">
    <h1 class="mb-4 text-center">Nos Menus</h1>

    <div class="row mb-4">
        <div class="col-md-4">
            <select id="priceFilter" class="form-select">
                <option value="">Filtrer par prix maximum</option>
                <option value="20">20 €</option>
                <option value="30">30 €</option>
                <option value="50">50 €</option>
                <option value="100">100 €</option>
            </select>
        </div>
    </div>

    <div class="row" id="menu-container">
        {% for menu in menus %}
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">

                    {% if menu.images|length > 0 %}
                        {% set firstImage = menu.images|first %}
                        <img src="{{ asset('uploads/menus/' ~ firstImage.url) }}" class="card-img-top" style="height: 200px; object-fit: cover;">
                    {% else %}
                        <img src="{{ asset('images/default.jpg') }}" class="card-img-top" style="height: 200px; object-fit: cover;">
                    {% endif %}

                    <div class="card-body">
                        <h5>{{ menu.titre }}</h5>
                        <p>{{ menu.description|striptags|slice(0,120) }}...</p>
                        <p><strong>{{ menu.prix }} €</strong></p>

                        <a href="{{ path('app_menu_show', {id: menu.id}) }}" class="btn btn-primary">
                            Voir détail
                        </a>
                    </div>

                </div>
            </div>
        {% else %}
            <p class="text-center">Aucun menu disponible.</p>
        {% endfor %}
    </div>
</div>

{% endblock %}

<!-- Ajout du lien script pour le filtre -->
{% block javascripts %}
{{ parent() }}
<script src="{{ asset('js/menu-filter.js') }}"></script>
{% endblock %}